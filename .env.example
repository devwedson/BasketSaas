APP_NAME=BasketSaas
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite (desenvolvimento local)
DB_CONNECTION=sqlite

# MySQL 8 (produção)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=basket_saas
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="contato@basketsaas.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Landing page (Neodunk)
LANDING_BRAND_NAME="${APP_NAME}"
LANDING_TAGLINE="Gestão profissional de basquete para clubes, times e atletas."
LANDING_LOGO=images/logo.svg
LANDING_PHONE=
LANDING_PHONE_DISPLAY=
LANDING_EMAIL=
LANDING_ADDRESS=
LANDING_SOCIAL_FACEBOOK=
LANDING_SOCIAL_INSTAGRAM=
LANDING_SOCIAL_LINKEDIN=
LANDING_SOCIAL_YOUTUBE=
LANDING_CTA_HEADER="Entrar"
LANDING_CTA_HEADER_ROUTE=login

# Attex (painel / login)
AUTH_PAGE_TITLE="Entrar"
AUTH_PAGE_SUBTITLE="Acesse o painel de gestão do seu clube."
AUTH_PAGE_FOOTER="${APP_NAME}"
